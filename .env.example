# ══════════════════════════════════════════════════════════════════════════════
# CommerceAgent — Environment Configuration
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: anthropic | ollama | huggingface_local | huggingface_api | openai
LLM_PROVIDER=ollama

# Anthropic (production default — best results)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (fully local, no API key needed)
# Install: https://ollama.ai  |  then: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# HuggingFace Local (downloads model weights ~2GB)
HF_MODEL=microsoft/Phi-3-mini-4k-instruct
HF_DEVICE=cpu   # or: cuda | mps

# HuggingFace Inference API (no local GPU needed)
HF_API_KEY=your_hf_api_key_here
HF_API_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ── Observability ─────────────────────────────────────────────────────────────
# LangSmith tracing (free tier at https://smith.langchain.com)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=commerceagent

# ── RAG Configuration ─────────────────────────────────────────────────────────
RAG_MODE=vector
CHROMA_PERSIST_DIR=./data/chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=5

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/runs.db

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ── Quality Gate ──────────────────────────────────────────────────────────────
# Minimum content quality score to pass (0-100)
QUALITY_GATE_THRESHOLD=70
# Max retries before returning best available output with warning
QUALITY_GATE_MAX_RETRIES=3

# ── MCP Server Ports ──────────────────────────────────────────────────────────
RETAILER_MCP_PORT=8001
CATALOG_MCP_PORT=8002
SCORING_MCP_PORT=8003

# ── Guardrails ────────────────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true
HALLUCINATION_DETECTION=true
BRAND_SAFETY_ENABLED=true
PII_DETECTION_ENABLED=true
